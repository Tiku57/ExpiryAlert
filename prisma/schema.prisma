generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NextAuth standard models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  
  accounts      Account[]
  sessions      Session[]
  
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  users        User[]
  records      Record[]
  categories   Category[]
  departments  Department[]
  owners       Owner[]
}

model Category {
  id             String       @id @default(cuid())
  name           String
  color          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  records        Record[]
}

model Department {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  records        Record[]
}

model Owner {
  id             String       @id @default(cuid())
  name           String
  email          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  records        Record[]
}

model Record {
  id             String       @id @default(cuid())
  title          String
  description    String?
  expiryDate     DateTime
  status         String       @default("Active") // Active, Expiring Soon, Critical, Expired
  priority       String       @default("Medium") // Low, Medium, High, Critical
  tags           String?      // comma separated or JSON
  notes          String?
  
  categoryId     String?
  category       Category?     @relation(fields: [categoryId], references: [id])
  
  departmentId   String?
  department     Department?   @relation(fields: [departmentId], references: [id])
  
  ownerId        String?
  owner          Owner?        @relation(fields: [ownerId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  renewalHistory RenewalHistory[]
  activityLogs   ActivityLog[]
  attachments    Attachment[]
  reminders      Reminder[]
  notifications  Notification[]
}

model RenewalHistory {
  id             String   @id @default(cuid())
  recordId       String
  record         Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  
  previousExpiry DateTime
  newExpiry      DateTime
  renewedAt      DateTime @default(now())
  renewedBy      String?  // user id or name
  notes          String?
}

model ActivityLog {
  id          String   @id @default(cuid())
  recordId    String?
  record      Record?  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  
  action      String   // Created, Updated, Renewed, Expired, Deleted
  details     String?
  userId      String?
  createdAt   DateTime @default(now())
}

model Attachment {
  id          String   @id @default(cuid())
  recordId    String
  record      Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  
  fileName    String
  fileUrl     String
  fileType    String?
  fileSize    Int?
  uploadedAt  DateTime @default(now())
}

model Reminder {
  id             String   @id @default(cuid())
  recordId       String
  record         Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  
  daysBeforeExpiry Int      // e.g. 30, 7, 1
  isSent           Boolean  @default(false)
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  message     String
  isRead      Boolean  @default(false)
  
  recordId    String?
  record      Record?  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}
